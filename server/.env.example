# ─── DATABASE ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/akirareads?schema=public"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET="akirareads-secret-ganti-ini-minimal-32-karakter-random"

# ─── SERVER ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
SERVER_URL="https://backend-production-xxxx.up.railway.app"
CLIENT_URL="https://akirareads-production.up.railway.app"

# ─── ADMIN ────────────────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@akirareads.com"
ADMIN_PASSWORD="Admin123"
ADMIN_USERNAME="admin"

# ─── SECURITY ─────────────────────────────────────────────────────────────────
# Kunci untuk proteksi admin API endpoint (isi di Railway)
ADMIN_API_KEY="kunci-rahasia-admin-ganti-ini"

# Untuk emergency reset password admin
# RESET_ADMIN_KEY="kunci-darurat"
